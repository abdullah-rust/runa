{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "runa",
  "version": "0.1.0",
  "identifier": "com.hero.runa",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
  {
    "title": "runa",
    "fullscreen": true,
    "resizable": true,
    "decorations": true
  }
],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
